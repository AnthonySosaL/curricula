# ============================================================
# Backend — Variables de entorno
# Copia este archivo como .env y llena los valores
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Base de datos — Neon PostgreSQL ──────────────────────────
# Obtener en: https://console.neon.tech
# DATABASE_URL → conexión pooled (para runtime serverless)
# DIRECT_URL   → conexión directa (para migraciones Prisma CLI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/curricula?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/curricula?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-secreto-seguro-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
