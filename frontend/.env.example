# ============================================================
# Frontend — Variables de entorno
# Copia este archivo como .env y .env.production según corresponda
# Todas las vars DEBEN empezar con VITE_ para ser expuestas al cliente
# ============================================================

# ── API ───────────────────────────────────────────────────────
# URL base del backend. En producción apunta al dominio de Vercel.
# El prefijo /api lo agrega el cliente automáticamente.
VITE_API_BASE_URL="http://localhost:3001"

# ── App ───────────────────────────────────────────────────────
VITE_APP_NAME="Curricula"
VITE_APP_VERSION="1.0.0"
