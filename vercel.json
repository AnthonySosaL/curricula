{
  "buildCommand": "cd frontend && pnpm install && pnpm build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "functions": {
    "api/chat.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/_/backend/api/chat",
      "dest": "/api/chat",
      "methods": ["POST", "OPTIONS"]
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
